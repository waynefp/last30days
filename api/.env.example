# Copy this to .env and fill in your values

# API key to protect your endpoint (choose any strong password)
API_KEY=change_me_to_something_strong

# Comma-separated list of allowed frontend origins (your Vercel URL)
# Use * to allow all origins during testing, lock it down after
ALLOWED_ORIGINS=*

# Where the skill scripts are installed (default is fine if you used setup_vps.sh)
SKILLS_BASE=/root/.claude/skills
